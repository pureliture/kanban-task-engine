{
  "name": "kanban-task-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Environment-independent task synchronization and automation engine",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "docs:verify": "python3 scripts/verify-docs.py",
    "test:docs": "vitest run scripts/verify-docs.test.ts && pnpm docs:verify",
    "eval:hardening": "node --import tsx scripts/check-hardening.ts",
    "eval:superpowers": "node --import tsx scripts/eval-superpowers.ts",
    "eval:superpowers:full": "node --import tsx scripts/eval-superpowers.ts --with-tests",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "migrate": "tsx scripts/migrate-tickets.ts"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
