{
  "name": "@kanban-task-engine/core",
  "version": "0.1.0",
  "description": "Core engine for task synchronization and automation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./executor": {
      "types": "./dist/executor/index.d.ts",
      "default": "./dist/executor/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "execa": "^8.0.1",
    "yaml": "^2.4.0",
    "@kanban-task-engine/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
